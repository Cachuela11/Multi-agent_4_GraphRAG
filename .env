# Ollama 配置（本地免费）
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace Embedding 模型（本地免费，首次运行自动下载）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ChromaDB 配置
CHROMA_PERSIST_DIR=./index

# 检索配置
RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# BM25 配置
BM25_INDEX_PATH=./index/bm25_index.pkl

# Reranker 配置
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_K=20
RRF_K=60
